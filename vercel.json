{
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/Dashboard.html", "dest": "/Dashboard.html" },
    { "src": "/Doc.html", "dest": "/Doc.html" },
    { "src": "/Windraw.html", "dest": "/Windraw.html" },
    { "src": "/Chat.html", "dest": "/Chat.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
